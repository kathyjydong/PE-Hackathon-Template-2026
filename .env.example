# Copy to .env (never commit .env). Values below are dev placeholders — use strong secrets in production.
#
# true for local dev; use false in Docker when benchmarking (lower latency).
FLASK_DEBUG=true
DATABASE_NAME=hackathon_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

DEVELOPEMENT_ENV=true

# Docker only: published port for direct access to gunicorn (avoid 5000 on Mac / AirPlay)
HOST_APP_PORT=5001

# Redis: if unset or empty, app uses redis://localhost:6379 (Docker Compose overrides with redis://redis:6379/0)
REDIS_URL=redis://localhost:6379/0
# Startup retries if Redis is slow to accept connections (defaults: 30 attempts, 1.0s apart)
# REDIS_CONNECT_RETRIES=30
# REDIS_CONNECT_DELAY=1.0
SHORT_LINK_CACHE_TTL=3600
# Optional: log resolve Redis hit/miss (avoid under load)
# REDIS_RESOLVE_DEBUG=1

# Docker / gunicorn: raise if k6 still sees >5% errors (default in image 48)
# GUNICORN_WORKERS=64

# k6 on host: k6 run k6/load.js
# k6 in grafana/k6 (from repo root): docker run --rm -e K6_IN_DOCKER=1 -v "$PWD:/work" grafana/k6 run /work/k6/load.js
# Direct gunicorn: K6_DIRECT_APP=1 BASE_URL=http://127.0.0.1:5001 k6 run k6/load.js