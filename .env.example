# true for local dev; use false in Docker when benchmarking (lower latency).
FLASK_DEBUG=true
DATABASE_NAME=hackathon_db
DATABASE_HOST=localhost
# Host-side port (localhost). docker-compose.yml forces 5432 for app→db on the Compose network.
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

DEVELOPEMENT_ENV=true

# Docker only: published port for direct access to gunicorn (avoid 5000 on Mac / AirPlay)
HOST_APP_PORT=5001

# Optional: alias cache (Docker Compose sets redis://redis:6379/0 on app)
REDIS_URL=redis://localhost:6379/0
# Per-process pool for gthread (default 128)
# REDIS_MAX_CONNECTIONS=128
SHORT_LINK_CACHE_TTL=3600
# Silver alerts (keep real value in local .env only)
DISCORD_WEBHOOK_URL=
# Optional: log resolve Redis hit/miss (avoid under load)
# REDIS_RESOLVE_DEBUG=1

# Gunicorn: gthread + threads = concurrent resolve (Redis). Fewer workers × pool must fit Postgres.
# GUNICORN_WORKER_CLASS=gthread
# GUNICORN_WORKERS=4
# GUNICORN_THREADS=96
# GUNICORN_MAX_CONCURRENCY=512
# Managed Postgres (~22 conns/instance): each worker has its own pool. Per DB, roughly:
#   (GUNICORN_WORKERS × DATABASE_POOL_MAX) + (same for replicas if using DATABASE_READ_POOL_MAX) ≤ ~18
#   (leave headroom for superuser/monitoring). Scale out app replicas: divide the budget per container.
# DATABASE_POOL_MAX=4
# DATABASE_READ_POOL_MAX=4

# k6 on host: k6 run k6/load.js
# k6 in grafana/k6 (from repo root): docker run --rm -e K6_IN_DOCKER=1 -v "$PWD:/work" grafana/k6 run /work/k6/load.js
# Direct gunicorn: K6_DIRECT_APP=1 BASE_URL=http://127.0.0.1:5001 k6 run k6/load.js