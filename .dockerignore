# All Files to be ignored by dockerfile blueprint

# Secrets and Local Environments
.env
.venv
.git
*.pem
*.key
credentials.json
*service-account*.json

# Coverage / local tooling
.coverage
.coverage.*
htmlcov/
coverage.xml

# Python Cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Project Metadata
.github/
.gitignore
README.md
Dockerfile
.dockerignore
nginx.conf
docker-compose.yml
